  "paths": {
    "/api/version": {
      "get": {
        "tags": ["external-core"],
        "summary": "查看当前线上版本",
        "description": "公开返回当前部署实例暴露的应用版本号与 release tag，适合排查线上实例到底跑的是哪一版。",
        "operationId": "getRuntimeVersion",
        "x-permission": "public",
        "x-scope": "external",
        "x-order": 5,
        "security": [],
        "responses": {
          "200": {
            "description": "成功返回当前线上版本信息",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VersionInfo"
                },
                "example": {
                  "ok": true,
                  "version": "1.1.0",
                  "release_tag": "v1.1.0"
                }
              }
            }
          }
        }
      }
    },
    "/api/addresses/generate": {
      "post": {
        "tags": ["external-core"],
        "summary": "生成一个完整邮箱地址",
        "description": "推荐的发号入口。返回完整邮箱地址，客户端后续查询时直接把这个地址原样传回即可。`READ_API_KEY` 与 `ADMIN_API_KEY` 都可调用。",
        "operationId": "generateAddress",
        "x-permission": "read",
        "x-scope": "external",
        "x-order": 10,
        "responses": {
          "200": {
            "description": "成功生成完整邮箱地址",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean",
                      "const": true
                    },
                    "email": {
                      "type": "string",
                      "format": "email"
                    },
                    "domain": {
                      "type": "string"
                    },
                    "local_part": {
                      "type": "string"
                    },
                    "issued_at": {
                      "type": "string",
                      "format": "date-time"
                    }
                  },
                  "required": ["ok", "email", "domain", "local_part", "issued_at"]
                },
                "example": {
                  "ok": true,
                  "email": "oc8f3ab12cd@example.test",
                  "domain": "example.test",
                  "local_part": "oc8f3ab12cd",
                  "issued_at": "2026-03-21T09:00:00.000Z"
                }
              }
            }
          },
          "401": {
            "description": "未提供或提供了错误的 API Key"
          },
          "409": {
            "description": "当前没有可发放的 active 域名"
          },
          "429": {
            "description": "请求过快，触发写操作限流"
          }
        }
      }
    },
    "/api/latest": {
      "get": {
        "tags": ["external-ops"],
        "summary": "查询某个邮箱最新地址邮件",
        "description": "高级纯读接口。必须传完整邮箱地址，不支持只传 local-part；更推荐普通第三方自动化直接使用 `POST /api/latest/consume`。",
        "operationId": "getLatestEmail",
        "x-permission": "read",
        "x-scope": "external",
        "x-order": 20,
        "parameters": [
          {
            "name": "address",
            "in": "query",
            "required": true,
            "description": "完整邮箱地址，例如 `oc8f3ab12cd@example.test`。",
            "schema": {
              "type": "string"
            },
            "example": "oc8f3ab12cd@example.test"
          }
        ],
        "responses": {
          "200": {
            "description": "成功返回最新地址邮件；如果还没收到邮件，`email` 为 null",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean",
                      "const": true
                    },
                    "email": {
                      "oneOf": [
                        {
                          "type": "object",
                          "properties": {
                            "id": {
                              "type": "integer"
                            },
                            "recipient": {
                              "type": "string",
                              "format": "email"
                            },
                            "sender": {
                              "type": "string"
                            },
                            "subject": {
                              "type": "string"
                            },
                            "body": {
                              "type": "string"
                            },
                            "received_at": {
                              "type": "string",
                              "format": "date-time"
                            },
                            "is_read": {
                              "type": "integer",
                              "enum": [0, 1]
                            }
                          },
                          "required": [
                            "id",
                            "recipient",
                            "sender",
                            "subject",
                            "body",
                            "received_at",
                            "is_read"
                          ]
                        },
                        {
                          "type": "null"
                        }
                      ]
                    }
                  },
                  "required": ["ok", "email"]
                },
                "example": {
                  "ok": true,
                  "email": {
                    "id": 777,
                    "recipient": "oc8f3ab12cd@example.test",
                    "sender": "noreply@tm.openai.com",
                    "subject": "你的 ChatGPT 代码为 014684",
                    "body": "输入此临时验证码以继续：\n014684\n如果并非你本人尝试创建 ChatGPT 帐户，请忽略此电子邮件。",
                    "received_at": "2026-03-21T09:02:03.530Z",
                    "is_read": 0
                  }
                }
              }
            }
          },
          "400": {
            "description": "缺少 address 参数"
          },
          "401": {
            "description": "未提供或提供了错误的 API Key"
          },
          "429": {
            "description": "请求过快，触发读取限流"
          }
        }
      }
    },
    "/api/latest/consume": {
      "post": {
        "tags": ["external-core"],
        "summary": "消费一封最新地址邮件",
        "description": "公开主链推荐入口。默认只匹配最新地址未读邮件，并通过 `action` 控制是只查看、标记已读还是删除；返回值始终带上选中的邮件快照，便于直接提取验证码。",
        "operationId": "consumeLatestEmail",
        "x-permission": "read",
        "x-scope": "external",
        "x-order": 20,
        "requestBody": {
          "required": true,
          "description": "目标邮箱地址与消费动作。`unread_only` 默认 `true`，`action` 默认 `peek`。",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "address": {
                    "type": "string",
                    "format": "email"
                  },
                  "unread_only": {
                    "type": "boolean"
                  },
                  "action": {
                    "type": "string",
                    "enum": ["peek", "mark_read", "delete"]
                  }
                },
                "required": ["address"]
              },
              "example": {
                "address": "oc8f3ab12cd@example.test",
                "unread_only": true,
                "action": "delete"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功返回目标邮件；如果当前没有匹配邮件，`email` 为 null。",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean",
                      "const": true
                    },
                    "email": {
                      "oneOf": [
                        {
                          "type": "object",
                          "properties": {
                            "id": {
                              "type": "integer"
                            },
                            "recipient": {
                              "type": "string",
                              "format": "email"
                            },
                            "sender": {
                              "type": "string"
                            },
                            "subject": {
                              "type": "string"
                            },
                            "body": {
                              "type": "string"
                            },
                            "received_at": {
                              "type": "string",
                              "format": "date-time"
                            },
                            "is_read": {
                              "type": "integer",
                              "enum": [0, 1]
                            }
                          },
                          "required": [
                            "id",
                            "recipient",
                            "sender",
                            "subject",
                            "body",
                            "received_at",
                            "is_read"
                          ]
                        },
                        {
                          "type": "null"
                        }
                      ]
                    }
                  },
                  "required": ["ok", "email"]
                },
                "example": {
                  "ok": true,
                  "email": {
                    "id": 777,
                    "recipient": "oc8f3ab12cd@example.test",
                    "sender": "noreply@tm.openai.com",
                    "subject": "你的 ChatGPT 代码为 014684",
                    "body": "输入此临时验证码以继续：\n014684\n如果并非你本人尝试创建 ChatGPT 帐户，请忽略此电子邮件。",
                    "received_at": "2026-03-21T09:02:03.530Z",
                    "is_read": 0
                  }
                }
              }
            }
          },
          "400": {
            "description": "缺少 address、action 非法、unread_only 非法或请求体不是合法 JSON"
          },
          "401": {
            "description": "未提供或提供了错误的 API Key"
          },
          "429": {
            "description": "请求过快，触发 consume 写操作限流"
          }
        }
      }
    },
    "/api/emails": {
      "get": {
        "tags": ["external-ops"],
        "summary": "列出邮件列表",
        "description": "支持按地址、发件人、主题、关键字、时间范围和排序方式查询。若 `summary=1`，返回更轻量的摘要结构。",
        "operationId": "listEmails",
        "x-permission": "read",
        "x-scope": "external",
        "x-order": 30,
        "parameters": [
          {
            "name": "address",
            "in": "query",
            "required": false,
            "description": "完整收件邮箱地址。",
            "schema": {
              "type": "string"
            },
            "example": "oc8f3ab12cd@example.test"
          },
          {
            "name": "sender",
            "in": "query",
            "required": false,
            "description": "按发件人过滤。",
            "schema": {
              "type": "string"
            },
            "example": "noreply@tm.openai.com"
          },
          {
            "name": "subject",
            "in": "query",
            "required": false,
            "description": "按主题过滤。",
            "schema": {
              "type": "string"
            },
            "example": "ChatGPT"
          },
          {
            "name": "q",
            "in": "query",
            "required": false,
            "description": "全文关键字检索。",
            "schema": {
              "type": "string"
            },
            "example": "014684"
          },
          {
            "name": "start",
            "in": "query",
            "required": false,
            "description": "起始时间，ISO 格式。",
            "schema": {
              "type": "string"
            },
            "example": "2026-03-20T00:00:00.000Z"
          },
          {
            "name": "end",
            "in": "query",
            "required": false,
            "description": "结束时间，ISO 格式。",
            "schema": {
              "type": "string"
            },
            "example": "2026-03-21T23:59:59.999Z"
          },
          {
            "name": "since_id",
            "in": "query",
            "required": false,
            "description": "仅返回 ID 大于该值的邮件。",
            "schema": {
              "type": "integer"
            },
            "example": 700
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "description": "排序方式。",
            "schema": {
              "type": "string",
              "enum": ["desc", "asc"]
            },
            "example": "desc"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "返回条数上限，最大 100。",
            "schema": {
              "type": "integer"
            },
            "example": 20
          },
          {
            "name": "summary",
            "in": "query",
            "required": false,
            "description": "传 `1` 时返回轻量摘要结构。",
