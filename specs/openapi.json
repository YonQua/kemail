  "tags": [
    {
      "name": "external-core",
      "description": "第三方业务、自动化脚本和 AI 最推荐直接接入的主链接口，围绕“发地址、消费最新地址邮件”这条最短路径收口。",
      "x-title": "对外集成接口 · 主链",
      "x-kicker": "External Core"
    },
    {
      "name": "external-ops",
      "description": "仍然保留实现、但更偏内部调试和高级用法的外部接口，例如 latest 查询、列表回溯、详情读取、显式删除和批量标已读。",
      "x-title": "对外扩展接口 · 高级/内部",
      "x-kicker": "External Ops"
    },
    {
      "name": "admin-mail",
      "description": "邮件写操作与原始内容读取，主要供后台管理、清理和调试使用。",
      "x-title": "后台管理接口 · 邮件管理",
      "x-kicker": "Admin Mail Ops"
    },
    {
      "name": "admin-analytics",
      "description": "数据看板使用的统计接口，带短 TTL 缓存，适合后台看板与运营监控。",
      "x-title": "后台管理接口 · 数据看板",
      "x-kicker": "Admin Analytics"
    },
    {
      "name": "admin-domains",
      "description": "域名池同步、启停和发号接口，主要供后台运维与域名池治理使用。",
      "x-title": "后台管理接口 · 域名池管理",
      "x-kicker": "Admin Domain Pool"
    }
  ],
  "x-docs": {
    "responseEnvelope": "所有接口默认返回 `{ ok: true, ... }` 或 `{ ok: false, error: \"...\" }`。文档页默认展示成功示例，并列出常见错误状态码。",
    "contractInfo": "仓库中的 `specs/openapi.json` 是单一契约源；构建产物会拆分为公开的 `/openapi.json` / `/api-docs`，以及管理员可见的内部文档入口。",
    "quickstart": [
      {
        "method": "post",
        "path": "/api/addresses/generate",
        "kicker": "Step 1",
        "title": "生成一个完整邮箱地址",
        "description": "推荐的发号入口。返回完整邮箱地址，后续查询时直接把这个地址原样传回即可。"
      },
      {
        "method": "post",
        "path": "/api/latest/consume",
        "kicker": "Step 2",
        "title": "消费一封最新地址邮件",
        "description": "统一的验证码消费入口。默认只取最新地址未读邮件，并可选择 peek、mark_read 或 delete 三种动作。"
      }
    ]
  },
