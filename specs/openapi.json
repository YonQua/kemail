            "application/json": {
              "example": {
                "zone_ids": ["zone-primary", "zone-secondary"],
                "issuable_enabled": 1
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "批量更新成功",
            "content": {
              "application/json": {
                "example": {
                  "ok": true,
                  "updated": ["zone-primary", "zone-secondary"],
                  "missing": [],
                  "updated_count": 2,
                  "issuable_enabled": 1
                }
              }
            }
          },
          "400": {
            "description": "请求体不是合法 JSON、缺少 zone_ids、超过上限或 `issuable_enabled` 非 0/1"
          },
          "401": {
            "description": "未提供或提供了错误的 API Key"
          },
          "403": {
            "description": "当前密钥不是管理员密钥"
          },
          "503": {
            "description": "`managed_domains` 表缺失"
          }
        }
      }
    }
  }
}
